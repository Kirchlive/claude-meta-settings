{
  "name": "claude-meta-settings",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env.local turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "postinstall": "sh scripts/patch-next-proxy-timeout.sh || true",
    "db:init": "node scripts/db.mjs init",
    "db:start": "node scripts/db.mjs start",
    "db:stop": "node scripts/db.mjs stop",
    "setup": "node scripts/db.mjs init && pnpm build && pnpm --filter backend db:migrate && sh scripts/install-claude-hooks.sh",
    "start": "node scripts/claude-meta-supervisor.mjs up",
    "stop": "node scripts/claude-meta-supervisor.mjs down"
  },
  "dependencies": {
    "embedded-postgres": "16.13.0-beta.17"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.5",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
